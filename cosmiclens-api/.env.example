# CosmicLens API - Environment Configuration

# Database Configuration
# Set to 'sqlite' for SQLite (default, no installation needed)
# Set to 'postgresql' for PostgreSQL
DATABASE_TYPE=sqlite

# SQLite settings
DATABASE_PATH=cosmiclens.db

# PostgreSQL settings (used if DATABASE_TYPE=postgresql)
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=cosmiclens
# DATABASE_USER=postgres
# DATABASE_PASSWORD=your_password

# API Configuration
API_TITLE=CosmicLens API
API_VERSION=1.0.0
API_DESCRIPTION=A RESTful API for NASA's Astronomy Picture of the Day

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true
